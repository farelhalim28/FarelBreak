<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.farel_break">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FarelBreak"
        android:usesCleartextTraffic="true">

        <!-- LAUNCHER: SplashScreen -->
        <activity
            android:name=".BreakApps.SplashScreenActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login -->
        <activity
            android:name=".BreakApps.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustPan" />

        <!-- ✅ BaseActivity: theme SAMA dengan app, jangan NoActionBar terpisah -->
        <activity
            android:name=".BreakApps.BaseActivity"
            android:exported="false" />

        <!-- Activity dalam folder Home -->
        <activity android:name=".BreakApps.Home.WelcomeActivity" android:exported="false" />
        <activity android:name=".BreakApps.Home.CalculatorActivity" android:exported="false" />
        <activity android:name=".BreakApps.Home.CustomTwoActivity" android:exported="false" />
        <activity android:name=".BreakApps.Home.WebViewActivity" android:exported="false" />

        <!-- MainActivity tetap didaftarkan -->
        <activity android:name=".BreakApps.MainActivity" android:exported="false" />

    </application>
</manifest>